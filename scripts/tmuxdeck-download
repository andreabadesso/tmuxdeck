#!/bin/bash
# Downloads a file to the local browser.
# Usage: tmuxdeck-download <file>
#
# Install: cp scripts/tmuxdeck-download /usr/local/bin/ && chmod +x /usr/local/bin/tmuxdeck-download

if [ -z "$1" ]; then
  echo "Usage: tmuxdeck-download <file>" >&2
  exit 1
fi

path="$(realpath "$1" 2>/dev/null || echo "$1")"

if [ ! -f "$path" ]; then
  echo "tmuxdeck-download: $path: No such file" >&2
  exit 1
fi

if [ -n "$TMUX" ]; then
  # Inside tmux: wrap in DCS passthrough (requires allow-passthrough on)
  printf '\ePtmux;\e\e]7338;%s\a\e\\' "$path"
else
  # Direct terminal
  printf '\e]7338;%s\a' "$path"
fi
