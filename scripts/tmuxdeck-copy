#!/bin/bash
# Copies stdin to the local browser clipboard via OSC 52 escape sequence.
# Usage: echo "hello" | tmuxdeck-copy
#        cat myfile.txt | tmuxdeck-copy
#
# Install: cp scripts/tmuxdeck-copy /usr/local/bin/ && chmod +x /usr/local/bin/tmuxdeck-copy

data="$(cat)"
if [ -z "$data" ]; then
  echo "tmuxdeck-copy: nothing to copy (stdin is empty)" >&2
  exit 1
fi

b64="$(printf '%s' "$data" | base64 | tr -d '\n')"

if [ -n "$TMUX" ]; then
  # Inside tmux: wrap in DCS passthrough (requires allow-passthrough on)
  printf '\ePtmux;\e\e]52;c;%s\a\e\\' "$b64"
else
  # Direct terminal
  printf '\e]52;c;%s\a' "$b64"
fi
